    borderRadius: AppRadius.buttonRadius,  // 12dp
    boxShadow: AppTheme.glowViolet,
  ),
  child: Center(
    child: Text(
      'Devam Et',
      style: TextStyle(
        color: AppTheme.textInverse,
        fontSize: 16,
        fontWeight: FontWeight.w700,
